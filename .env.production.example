# ===================================
# CONFIGURACIÓN PRODUCCIÓN AWS
# ===================================

# APLICACIÓN
APP_ENV=production
APP_SYSTEM=linux
APP_DEBUG=false
APP_KEY=                    # GENERAR CON: php artisan key:generate
APP_LOG_LEVEL=error         # error | critical | alert | emergency
APP_URL=https://api.tudominio.com
APP_NAME=TaxisApp
APP_VERSION=v1.0.0
APP_COLOR=2376dc

# BASE DE DATOS (AWS RDS)
DB_HOST=                    # Endpoint de RDS: xxx.rds.amazonaws.com
DB_DATABASE=taxisapp
DB_PORT=3306
DB_USERNAME=                # Usuario de RDS
DB_PASSWORD=                # Contraseña segura de RDS

# API DINGO
API_STANDARDS_TREE=x
API_NAME=API
API_DEBUG=false
API_PREFIX=api
API_VERSION=v1

# ALMACENAMIENTO (AWS S3)
FILESYSTEM=s3
AWS_KEY=                    # NEW IAM Key (NO usar las actuales expuestas)
AWS_SECRET=                 # NEW IAM Secret
AWS_REGION=us-east-1
AWS_BUCKET=taxisapp-production

# CACHE Y SESIONES (AWS ElastiCache/Redis)
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_DRIVER=redis

REDIS_HOST=                 # Endpoint de ElastiCache
REDIS_PASSWORD=null
REDIS_PORT=6379

# CORREO (AWS SES)
MAIL_DRIVER=ses
MAIL_HOST=email-smtp.us-east-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=              # NEW SES SMTP User
MAIL_PASSWORD=              # NEW SES SMTP Password
MAIL_ENCRYPTION=tls
MAIL_ADDRESS=notifications@tudominio.com

MAIL_DOMAIN=tudominio.com
MAIL_SECRET=                # NEW Mailgun Key si lo usas

AWS_SES_KEY=                # NEW SES Key
AWS_SES_SECRET=             # NEW SES Secret

# PAYPAL (Usar credenciales de producción)
PAYPAL_CLIENT_ID=           # PRODUCCIÓN (diferente a sandbox)
PAYPAL_CLIENT_SECRET=       # PRODUCCIÓN

# GOOGLE CLOUD
GOOGLE_CLOUD_API=           # RESTRICCIÓN POR DOMINIO EN CONSOLA

# TWILIO (Producción)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=

# ONESIGNAL
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# JWT
JWT_SECRET=                 # GENERAR NUEVO con: php artisan jwt:secret
JWT_TTL=60                  # 60 minutos
